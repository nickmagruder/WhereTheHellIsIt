# Database — Aurora Serverless v2 via RDS Proxy
DATABASE_URL=postgresql://dev:dev@localhost:5432/wherethehellistit
DATABASE_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:dev/db-credentials

# Cognito
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID_WEB=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_ID_MOBILE=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AppSync
APPSYNC_ENDPOINT=https://xxxxxxxxxxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql
APPSYNC_REGION=us-east-1

# S3 (photos + thumbnails)
S3_PHOTOS_BUCKET=wthi-dev-photos
S3_THUMBNAILS_BUCKET=wthi-dev-thumbnails

# CloudFront
CLOUDFRONT_DOMAIN=xxxxxxxxxxxxxxxxxx.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=KXXXXXXXXXXXXXX
CLOUDFRONT_PRIVATE_KEY_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:dev/cloudfront-key

# AWS
AWS_REGION=us-east-1
