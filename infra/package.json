{
  "name": "@wthi/infra",
  "version": "0.0.1",
  "private": true,
  "description": "AWS CDK infrastructure — all stacks for WhereTheHellIsIt",
  "scripts": {
    "lint": "eslint bin lib --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit",
    "cdk": "cdk",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy:dev": "cdk deploy --all --context env=dev",
    "deploy:prod": "cdk deploy --all --context env=prod --require-approval broadening"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.180.0",
    "cdk-nag": "^2.32.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "aws-cdk": "^2.180.0",
    "tsx": "^4.19.2"
  }
}
